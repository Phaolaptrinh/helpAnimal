@{
    Layout = "_Layout";
    ViewData["Title"] = "Bác sĩ thú cưng AI - Petlor";
}

<style>
    .vetai-wrapper {
        max-width: 780px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .vetai-header {
        text-align: center;
        margin-bottom: 1.5rem;
    }

        .vetai-header .avatar {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: linear-gradient(135deg, #2F6F4E, #4a9970);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin: 0 auto 12px;
            box-shadow: 0 4px 14px rgba(47,111,78,0.3);
        }

        .vetai-header h2 {
            margin: 0;
            font-weight: 700;
            color: #1F2A24;
        }

        .vetai-header p {
            color: #6c757d;
            font-size: 0.9rem;
            margin-top: 4px;
        }

    .vetai-box {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.08);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 65vh;
        min-height: 480px;
    }

    .vetai-messages {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 14px;
        background: #f8faf9;
    }

    .msg-row {
        display: flex;
        gap: 10px;
        max-width: 85%;
    }

        .msg-row.user {
            align-self: flex-end;
            flex-direction: row-reverse;
        }

    .msg-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1rem;
    }

        .msg-avatar.ai {
            background: #2F6F4E;
            color: #fff;
        }

        .msg-avatar.user {
            background: #F2A93B;
            color: #1F2A24;
        }

    .msg-bubble {
        padding: 10px 16px;
        border-radius: 16px;
        font-size: 0.92rem;
        line-height: 1.5;
        white-space: pre-wrap;
    }

    .msg-row.ai .msg-bubble {
        background: #fff;
        border: 1px solid #e9ecef;
        border-top-left-radius: 4px;
        color: #212529;
    }

    .msg-row.user .msg-bubble {
        background: #2F6F4E;
        color: #fff;
        border-top-right-radius: 4px;
    }

    .vetai-suggestions {
        padding: 0 1.5rem 1rem;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        background: #f8faf9;
    }

    .suggestion-chip {
        background: #fff;
        border: 1px solid #d8e3dc;
        color: #2F6F4E;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.82rem;
        cursor: pointer;
        transition: all 0.2s;
    }

        .suggestion-chip:hover {
            background: #2F6F4E;
            color: #fff;
        }

    .vetai-input-area {
        padding: 1rem 1.25rem;
        border-top: 1px solid #eee;
        display: flex;
        gap: 10px;
        background: #fff;
    }

        .vetai-input-area input {
            flex: 1;
            border: 1px solid #dee2e6;
            border-radius: 24px;
            padding: 10px 18px;
            font-size: 0.95rem;
            outline: none;
        }

            .vetai-input-area input:focus {
                border-color: #2F6F4E;
            }

    .vetai-send-btn {
        background: #2F6F4E;
        color: #fff;
        border: none;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.2s;
        flex-shrink: 0;
    }

        .vetai-send-btn:hover {
            background: #245a3f;
        }

        .vetai-send-btn:disabled {
            background: #adb5bd;
            cursor: not-allowed;
        }

    .typing-indicator {
        display: flex;
        gap: 4px;
        padding: 10px 16px;
    }

        .typing-indicator span {
            width: 7px;
            height: 7px;
            background: #adb5bd;
            border-radius: 50%;
            animation: blink 1.4s infinite both;
        }

            .typing-indicator span:nth-child(2) {
                animation-delay: 0.2s;
            }

            .typing-indicator span:nth-child(3) {
                animation-delay: 0.4s;
            }

    @@keyframes blink {
        0%, 80%, 100% {
            opacity: 0.3;
        }

        40% {
            opacity: 1;
        }
    }

    .vetai-disclaimer {
        text-align: center;
        font-size: 0.78rem;
        color: #adb5bd;
        margin-top: 10px;
    }
</style>

<div class="vetai-wrapper">
    <div class="vetai-header">
        <div class="avatar">🩺</div>
        <h2>Bác sĩ thú cưng AI</h2>
        <p>Tư vấn nhanh về sức khỏe, dinh dưỡng và hành vi của thú cưng — miễn phí, 24/7</p>
    </div>

    <div class="vetai-box">
        <div class="vetai-messages" id="chatMessages">
            <div class="msg-row ai">
                <div class="msg-avatar ai">🐾</div>
                <div class="msg-bubble">
                    Chào bạn! Mình là bác sĩ thú cưng AI của Petlor 🐶🐱<br />
                    Bạn có thể hỏi mình về sức khỏe, dinh dưỡng, tiêm phòng hay hành vi của thú cưng nhé!
                </div>
            </div>
        </div>

        <div class="vetai-suggestions" id="suggestionChips">
            <div class="suggestion-chip">Chó bỏ ăn phải làm sao?</div>
            <div class="suggestion-chip">Lịch tiêm phòng cho mèo con</div>
            <div class="suggestion-chip">Dấu hiệu chó bị stress</div>
            <div class="suggestion-chip">Mèo nôn liên tục có nguy hiểm không?</div>
        </div>

        <div class="vetai-input-area">
            <input type="text" id="chatInput" placeholder="Nhập câu hỏi về thú cưng của bạn..." />
            <button class="vetai-send-btn" id="sendBtn">
                <i class="bi bi-send-fill"></i>
            </button>
        </div>
    </div>

    <p class="vetai-disclaimer">
        ⚠️ AI chỉ tư vấn tham khảo, không thay thế khám trực tiếp. Trường hợp khẩn cấp, vui lòng đặt lịch khám ngay.
    </p>
</div>

<script>
    const chatMessages = document.getElementById('chatMessages');
    const chatInput = document.getElementById('chatInput');
    const sendBtn = document.getElementById('sendBtn');
    const suggestionChips = document.getElementById('suggestionChips');

    let history = [];

    function addMessage(role, content) {
        const row = document.createElement('div');
        row.className = `msg-row ${role === 'user' ? 'user' : 'ai'}`;

        const avatar = document.createElement('div');
        avatar.className = `msg-avatar ${role === 'user' ? 'user' : 'ai'}`;
        avatar.textContent = role === 'user' ? '🙋' : '🐾';

        const bubble = document.createElement('div');
        bubble.className = 'msg-bubble';
        bubble.textContent = content;

        row.appendChild(avatar);
        row.appendChild(bubble);
        chatMessages.appendChild(row);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function showTyping() {
        const row = document.createElement('div');
        row.className = 'msg-row ai';
        row.id = 'typingRow';

        const avatar = document.createElement('div');
        avatar.className = 'msg-avatar ai';
        avatar.textContent = '🐾';

        const bubble = document.createElement('div');
        bubble.className = 'msg-bubble';
        bubble.innerHTML = '<div class="typing-indicator"><span></span><span></span><span></span></div>';

        row.appendChild(avatar);
        row.appendChild(bubble);
        chatMessages.appendChild(row);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function removeTyping() {
        const typingRow = document.getElementById('typingRow');
        if (typingRow) typingRow.remove();
    }

    async function sendMessage(text) {
        if (!text.trim()) return;

        addMessage('user', text);
        history.push({ role: 'user', content: text });
        chatInput.value = '';
        sendBtn.disabled = true;
        suggestionChips.style.display = 'none';

        showTyping();

        try {
            const response = await fetch('/VetAi/Ask', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text, history: history })
            });

            const data = await response.json();
            removeTyping();
            addMessage('ai', data.reply);
            history.push({ role: 'assistant', content: data.reply });
        } catch (err) {
            removeTyping();
            addMessage('ai', 'Xin lỗi, có lỗi kết nối. Vui lòng thử lại sau.');
        }

        sendBtn.disabled = false;
    }

    sendBtn.addEventListener('click', () => sendMessage(chatInput.value));

    chatInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') sendMessage(chatInput.value);
    });

    document.querySelectorAll('.suggestion-chip').forEach(chip => {
        chip.addEventListener('click', () => sendMessage(chip.textContent));
    });
</script>