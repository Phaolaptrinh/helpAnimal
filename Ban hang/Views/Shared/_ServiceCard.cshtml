@model ServiceItem
<div class="svc-card reveal">
    <div class="svc-icon">
        <partial name="_ServiceIcon" model="Model.IconKey" />
    </div>
    <h3>@Model.Title</h3>
    <p>@Model.Description</p>
    <div class="svc-foot">
        <span class="svc-price">@Model.Price</span>
        <a href="#dat-lich" class="svc-link">
            Đặt lịch
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M13 6l6 6-6 6" />
            </svg>
        </a>
    </div>
</div>
