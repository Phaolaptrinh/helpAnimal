<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — Petlor Admin</title>

    <!-- AdminLTE CSS -->
    <link rel="stylesheet" href="~/adminlte/css/adminlte.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.min.css" />
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">

    <div class="app-wrapper">

        <!-- ===== HEADER ===== -->
        <nav class="app-header navbar navbar-expand bg-body">
            <div class="container-fluid">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="#" data-lte-toggle="sidebar">
                            <i class="bi bi-list"></i>
                        </a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <span class="nav-link">Xin chào, Admin</span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-sm btn-danger text-white ms-2"
                           asp-controller="Account"
                           asp-action="Logout"
                           asp-area="">
                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- ===== SIDEBAR ===== -->
        <aside class="app-sidebar bg-body-secondary shadow">
            <div class="sidebar-brand">
                <a href="#" class="brand-link">
                    <span class="brand-text fw-bold">🐾 Petlor Admin</span>
                </a>
            </div>
            <div class="sidebar-wrapper">
                <nav class="mt-2">
                    <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview">
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="Index" asp-area="" class="nav-link">
                                <i class="bi bi-speedometer2 nav-icon"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="Services" asp-area="" class="nav-link">
                                <i class="bi bi-grid nav-icon"></i>
                                <p>Dịch vụ</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="Products" asp-area="" class="nav-link">
                                <i class="bi bi-box-seam nav-icon"></i>
                                <p>Sản phẩm</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="Team" asp-area="" class="nav-link">
                                <i class="bi bi-people nav-icon"></i>
                                <p>Đội ngũ</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="Bookings" asp-area="" class="nav-link">
                                <i class="bi bi-calendar-check nav-icon"></i>
                                <p>Đặt lịch</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="BlogPosts" asp-area="" class="nav-link">
                                <i class="bi bi-file-text nav-icon"></i>
                                <p>Blog</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="Faqs" asp-area="" class="nav-link">
                                <i class="bi bi-question-circle nav-icon"></i>
                                <p>FAQ</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="Orders" asp-area="" class="nav-link">
                                <i class="bi bi-bag-check nav-icon"></i>
                                <p>Đơn hàng</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="Users" asp-area="" class="nav-link">
                                <i class="bi bi-person-badge nav-icon"></i>
                                <p>Tài khoản</p>
                            </a>
                        </li>
                    </ul>

                </nav>
            </div>
        </aside>

        <!-- ===== NỘI DUNG CHÍNH ===== -->
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <h3 class="mb-0">@ViewData["Title"]</h3>
                </div>
            </div>
            <div class="app-content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </div>
        </main>

        <footer class="app-footer">
            <strong>&copy; @DateTime.Now.Year Petlor Admin</strong>
        </footer>

    </div>

    <!-- jQuery (cần cho Summernote và AdminLTE) -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>

    <!-- AdminLTE JS -->
    <script src="~/adminlte/js/adminlte.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
