@model List<BlogPost>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý Blog";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">Danh sách bài viết</h3>
        <a asp-action="CreateBlogPost" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg"></i> Thêm bài viết
        </a>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped mb-0 align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Ảnh</th>
                    <th>Tag</th>
                    <th>Tiêu đề</th>
                    <th>Tóm tắt</th>
                    <th>Thời gian đọc</th>
                    <th style="width: 130px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>
                            <img src="@item.ImageUrl" width="60" height="40" class="rounded" style="object-fit:cover" />
                        </td>
                        <td><span class="badge text-bg-secondary">@item.Tag</span></td>
                        <td>@item.Title</td>
                        <td>@item.Excerpt</td>
                        <td>@item.ReadTime</td>
                        <td>
                            <a asp-action="EditBlogPost" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="DeleteBlogPost" asp-route-id="@item.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bạn chắc chắn muốn xóa?');">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>