@model Order
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
}

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Sản phẩm trong đơn</h3>
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Đơn giá</th>
                            <th>Số lượng</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.Price.ToString("N0") đ</td>
                                <td>@item.Quantity</td>
                                <td class="fw-bold">@((item.Price * item.Quantity).ToString("N0")) đ</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        @if (Model.DiscountAmount > 0)
                        {
                            <tr>
                                <td colspan="3" class="text-end">Giảm giá @(!string.IsNullOrEmpty(Model.VoucherCode) ? $"({Model.VoucherCode})" : ""):</td>
                                <td class="text-danger">-@Model.DiscountAmount.ToString("N0") đ</td>
                            </tr>
                        }
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                            <td class="fw-bold text-success fs-5">@Model.TotalAmount.ToString("N0") đ</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Thông tin khách hàng</h3>
            </div>
            <div class="card-body">
                <p><strong>Tên:</strong> @Model.CustomerName</p>
                <p><strong>SĐT:</strong> @Model.CustomerPhone</p>
                <p><strong>Địa chỉ:</strong> @Model.ShippingAddress</p>
                <p><strong>Ghi chú:</strong> @(string.IsNullOrEmpty(Model.Note) ? "—" : Model.Note)</p>
                <p><strong>Ngày đặt:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Trạng thái:</strong> <span class="badge text-bg-secondary">@Model.Status</span></p>
            </div>
        </div>
    </div>
</div>

<a asp-action="Orders" class="btn btn-secondary mt-2">← Quay lại danh sách</a>