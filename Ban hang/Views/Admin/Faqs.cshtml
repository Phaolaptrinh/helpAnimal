@model List<FaqItem>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý FAQ";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">Danh sách câu hỏi thường gặp</h3>
        <a asp-action="CreateFaq" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg"></i> Thêm câu hỏi
        </a>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped mb-0 align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Câu hỏi</th>
                    <th>Câu trả lời</th>
                    <th style="width: 130px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Question</td>
                        <td>@item.Answer</td>
                        <td>
                            <a asp-action="EditFaq" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="DeleteFaq" asp-route-id="@item.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bạn chắc chắn muốn xóa?');">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>