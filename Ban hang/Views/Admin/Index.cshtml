@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Dashboard";
}

<style>
    .stat-card {
        background: #fff;
        border-radius: 10px;
        border: 1px solid #e9ecef;
        padding: 1rem 1.25rem;
        height: 100%;
    }

    .stat-label {
        font-size: 0.75rem;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: 4px;
    }

    .stat-value {
        font-size: 1.6rem;
        font-weight: 700;
        margin: 0;
    }

    .section-title {
        font-size: 0.95rem;
        font-weight: 600;
        color: #495057;
        margin: 1.75rem 0 .75rem;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .chart-wrap {
        position: relative;
        height: 260px;
    }

    .chart-wrap-sm {
        position: relative;
        height: 200px;
    }

    .icon-badge {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
</style>

<div class="card mb-3">
    <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-calendar-range text-primary" style="font-size:1.2rem;"></i>
            <span class="fw-bold text-secondary" style="font-size:0.9rem;">Xem theo khoảng thời gian</span>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Index" asp-route-range="7days"
               class="btn btn-sm rounded-pill px-3 @(ViewData["CurrentRange"]?.ToString() == "7days" ? "btn-primary text-white" : "btn-light border")">
                <i class="bi bi-calendar-week"></i> 7 ngày
            </a>
            <a asp-action="Index" asp-route-range="30days"
               class="btn btn-sm rounded-pill px-3 @(ViewData["CurrentRange"]?.ToString() == "30days" ? "btn-primary text-white" : "btn-light border")">
                <i class="bi bi-calendar3"></i> 30 ngày
            </a>
            <a asp-action="Index" asp-route-range="thismonth"
               class="btn btn-sm rounded-pill px-3 @(ViewData["CurrentRange"]?.ToString() == "thismonth" ? "btn-primary text-white" : "btn-light border")">
                <i class="bi bi-calendar-event"></i> Tháng này
            </a>
            <a asp-action="Index" asp-route-range="thisyear"
               class="btn btn-sm rounded-pill px-3 @(ViewData["CurrentRange"]?.ToString() == "thisyear" ? "btn-primary text-white" : "btn-light border")">
                <i class="bi bi-calendar-check"></i> Năm nay
            </a>
        </div>
    </div>
</div>

<!-- ===== 4 SỐ LIỆU CHÍNH ===== -->
<div class="row g-3">
    <div class="col-lg-3 col-6">
        <div class="small-box text-bg-primary mb-0">
            <div class="inner">
                <h3>@ViewData["TotalBookings"]</h3>
                <p>Tổng đặt lịch</p>
            </div>
            <i class="bi bi-calendar3" style="position:absolute; right:16px; top:16px; font-size:2.2rem; opacity:.35;"></i>
            <a href="@Url.Action("Bookings")" class="small-box-footer link-light link-underline-opacity-0">
                Xem chi tiết <i class="bi bi-arrow-right-circle"></i>
            </a>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box text-bg-warning mb-0">
            <div class="inner">
                <h3>@ViewData["PendingBookings"]</h3>
                <p>Chờ xác nhận</p>
            </div>
            <i class="bi bi-hourglass-split" style="position:absolute; right:16px; top:16px; font-size:2.2rem; opacity:.35;"></i>
            <a href="@Url.Action("Bookings")" class="small-box-footer link-light link-underline-opacity-0">
                Xem chi tiết <i class="bi bi-arrow-right-circle"></i>
            </a>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box text-bg-success mb-0">
            <div class="inner">
                <h3>@ViewData["CompletedBookings"]</h3>
                <p>Hoàn thành</p>
            </div>
            <i class="bi bi-check-circle" style="position:absolute; right:16px; top:16px; font-size:2.2rem; opacity:.35;"></i>
            <a href="@Url.Action("Bookings")" class="small-box-footer link-light link-underline-opacity-0">
                Xem chi tiết <i class="bi bi-arrow-right-circle"></i>
            </a>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box text-bg-danger mb-0">
            <div class="inner">
                <h3>@ViewData["CancelledBookings"]</h3>
                <p>Đã hủy</p>
            </div>
            <i class="bi bi-x-circle" style="position:absolute; right:16px; top:16px; font-size:2.2rem; opacity:.35;"></i>
            <a href="@Url.Action("Bookings")" class="small-box-footer link-light link-underline-opacity-0">
                Xem chi tiết <i class="bi bi-arrow-right-circle"></i>
            </a>
        </div>
    </div>
</div>

<!-- ===== 2 KPI LỚN ===== -->
<div class="row g-3 mt-1">
    <div class="col-lg-6">
        <div class="stat-card d-flex align-items-center justify-content-between">
            <div>
                <div class="stat-label">Tỷ lệ hoàn thành</div>
                <p class="stat-value text-success">@ViewData["CompletionRate"]%</p>
                <small class="text-muted">Đặt lịch đã hoàn thành</small>
            </div>
            <div class="position-relative" style="width:72px;height:72px;">
                <svg width="72" height="72" viewBox="0 0 72 72">
                    <circle cx="36" cy="36" r="30" fill="none" stroke="#e9ecef" stroke-width="7" />
                    <circle cx="36" cy="36" r="30" fill="none" stroke="#198754" stroke-width="7"
                            stroke-dasharray="@(2 * Math.PI * 30)"
                            stroke-dashoffset="@(2 * Math.PI * 30 * (1 - (double)ViewData["CompletionRate"]! / 100))"
                            stroke-linecap="round" transform="rotate(-90 36 36)" />
                </svg>
                <div class="position-absolute top-50 start-50 translate-middle">
                    <i class="bi bi-check-circle-fill text-success" style="font-size:1.3rem;"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="stat-card d-flex align-items-center justify-content-between">
            <div>
                <div class="stat-label">Thú cưng hot nhất</div>
                <p class="stat-value text-primary">@ViewData["TopPetType"]</p>
                <small class="text-muted">@ViewData["TopPetCount"] lượt đặt lịch</small>
            </div>
            <div class="icon-badge" style="background:#e7f1ff;">
                <i class="bi bi-heart-fill text-primary" style="font-size:1.5rem;"></i>
            </div>
        </div>
    </div>
</div>

<!-- ===== TỔNG QUAN NỘI DUNG ===== -->
<div class="section-title"><i class="bi bi-grid-3x3-gap"></i> Tổng quan nội dung</div>
<div class="row g-3">
    <div class="col-lg-2 col-4">
        <div class="stat-card text-center">
            <i class="bi bi-heart-pulse text-primary" style="font-size:1.3rem;"></i>
            <p class="stat-value mt-1">@ViewData["TotalServices"]</p>
            <small class="text-muted">Dịch vụ</small>
        </div>
    </div>
    <div class="col-lg-2 col-4">
        <div class="stat-card text-center">
            <i class="bi bi-people text-success" style="font-size:1.3rem;"></i>
            <p class="stat-value mt-1">@ViewData["TotalTeam"]</p>
            <small class="text-muted">Nhân viên</small>
        </div>
    </div>
    <div class="col-lg-2 col-4">
        <div class="stat-card text-center">
            <i class="bi bi-file-text text-warning" style="font-size:1.3rem;"></i>
            <p class="stat-value mt-1">@ViewData["TotalBlogs"]</p>
            <small class="text-muted">Bài viết</small>
        </div>
    </div>
    <div class="col-lg-2 col-4">
        <div class="stat-card text-center">
            <i class="bi bi-question-circle text-info" style="font-size:1.3rem;"></i>
            <p class="stat-value mt-1">@ViewData["TotalFaqs"]</p>
            <small class="text-muted">Câu hỏi FAQ</small>
        </div>
    </div>
    <div class="col-lg-2 col-4">
        <div class="stat-card text-center">
            <i class="bi bi-star text-danger" style="font-size:1.3rem;"></i>
            <p class="stat-value mt-1">@ViewData["TotalTestimonials"]</p>
            <small class="text-muted">Đánh giá</small>
        </div>
    </div>
    <div class="col-lg-2 col-4">
        <div class="stat-card text-center">
            <i class="bi bi-tags text-secondary" style="font-size:1.3rem;"></i>
            <p class="stat-value mt-1">@ViewData["TotalPriceTiers"]</p>
            <small class="text-muted">Gói giá</small>
        </div>
    </div>
</div>

<!-- ===== HOẠT ĐỘNG ĐẶT LỊCH ===== -->
<div class="section-title"><i class="bi bi-graph-up-arrow"></i> Hoạt động đặt lịch</div>
<div class="row g-3">
    <div class="col-lg-3 col-6">
        <div class="stat-card">
            <div class="stat-label">Hôm nay</div>
            <p class="stat-value text-primary">@ViewData["BookingsToday"]</p>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="stat-card">
            <div class="stat-label">Tuần này</div>
            <p class="stat-value text-info">@ViewData["BookingsThisWeek"]</p>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="stat-card">
            <div class="stat-label">Tháng này</div>
            <p class="stat-value text-success">@ViewData["BookingsThisMonth"]</p>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="stat-card">
            <div class="stat-label">Trung bình/ngày</div>
            <p class="stat-value text-warning">@ViewData["AvgBookingsPerDay"]</p>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-lg-6">
        <div class="stat-card d-flex align-items-center gap-3">
            <div class="icon-badge" style="background:#e7f7fb;">
                <i class="bi bi-clock-history text-info" style="font-size:1.3rem;"></i>
            </div>
            <div>
                <small class="text-muted d-block">Giờ cao điểm</small>
                <p class="mb-0 fw-bold">@ViewData["PeakHour"]</p>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="stat-card d-flex align-items-center gap-3">
            <div class="icon-badge" style="background:#e9f7ee;">
                <i class="bi bi-calendar-week text-success" style="font-size:1.3rem;"></i>
            </div>
            <div>
                <small class="text-muted d-block">Ngày đông khách nhất</small>
                <p class="mb-0 fw-bold">@ViewData["PeakDayOfWeek"]</p>
            </div>
        </div>
    </div>
</div>

<!-- ===== KHÁCH HÀNG ===== -->
<div class="section-title"><i class="bi bi-person-lines-fill"></i> Khách hàng</div>
<div class="row g-3">
    <div class="col-lg-4 col-6">
        <div class="stat-card text-center">
            <i class="bi bi-people-fill text-primary" style="font-size:1.3rem;"></i>
            <p class="stat-value mt-1">@ViewData["TotalCustomers"]</p>
            <small class="text-muted">Tổng khách hàng</small>
        </div>
    </div>
    <div class="col-lg-4 col-6">
        <div class="stat-card text-center">
            <i class="bi bi-person-plus text-success" style="font-size:1.3rem;"></i>
            <p class="stat-value mt-1">@ViewData["NewCustomersThisMonth"]</p>
            <small class="text-muted">Khách mới tháng này</small>
        </div>
    </div>
    <div class="col-lg-4 col-6">
        <div class="stat-card text-center">
            <i class="bi bi-arrow-repeat text-warning" style="font-size:1.3rem;"></i>
            <p class="stat-value mt-1">@ViewData["RetentionRate"]%</p>
            <small class="text-muted">Tỷ lệ quay lại</small>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-lg-6">
        <div class="stat-card d-flex align-items-center gap-3">
            <div class="icon-badge" style="background:#fbe9ea;">
                <i class="bi bi-arrow-down-circle text-danger" style="font-size:1.3rem;"></i>
            </div>
            <div>
                <small class="text-muted d-block">Dịch vụ ít được đặt nhất</small>
                <p class="mb-0 fw-bold">@ViewData["LeastService"]</p>
            </div>
        </div>
    </div>
</div>

<!-- ===== BIỂU ĐỒ ===== -->
<div class="section-title"><i class="bi bi-bar-chart-line"></i> Biểu đồ thống kê</div>
<div class="row g-3">
    <div class="col-lg-6">
        <div class="card mb-0">
            <div class="card-header py-2"><h3 class="card-title fs-6 mb-0">Đặt lịch 7 ngày gần nhất</h3></div>
            <div class="card-body">
                <div class="chart-wrap"><canvas id="bookingChart"></canvas></div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card mb-0">
            <div class="card-header py-2"><h3 class="card-title fs-6 mb-0">Phân bố trạng thái đặt lịch</h3></div>
            <div class="card-body">
                <div class="chart-wrap"><canvas id="statusChart"></canvas></div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-lg-12">
        <div class="card mb-0">
            <div class="card-header py-2"><h3 class="card-title fs-6 mb-0">Top 5 dịch vụ được đặt nhiều nhất</h3></div>
            <div class="card-body">
                <div class="chart-wrap-sm"><canvas id="serviceChart"></canvas></div>
            </div>
        </div>
    </div>
</div>

<!-- ===== BẢNG ===== -->
<div class="row g-3 mt-1 mb-3">
    <div class="col-lg-7">
        <div class="card mb-0">
            <div class="card-header py-2"><h3 class="card-title fs-6 mb-0">5 lịch đặt gần nhất</h3></div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0 align-middle">
                    <thead class="table-light">
                        <tr><th>Khách hàng</th><th>Dịch vụ</th><th>Ngày hẹn</th><th>Trạng thái</th></tr>
                    </thead>
                    <tbody>
                        @{
                            var recentBookings = ViewData["RecentBookings"] as List<Booking>;
                            if (recentBookings != null && recentBookings.Count > 0)
                            {
                                foreach (var b in recentBookings)
                                {
                                    var badgeClass = b.Status switch
                                    {
                                        "Chờ xác nhận" => "text-bg-warning",
                                        "Đã xác nhận" => "text-bg-info",
                                        "Hoàn thành" => "text-bg-success",
                                        "Đã hủy" => "text-bg-danger",
                                        _ => "text-bg-secondary"
                                    };
                                    <tr>
                                        <td class="fw-bold">@b.OwnerName</td>
                                        <td>@b.ServiceType</td>
                                        <td>@b.BookDate.ToString("dd/MM/yyyy")</td>
                                        <td><span class="badge @badgeClass">@b.Status</span></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="4" class="text-center text-muted py-3">Chưa có lịch đặt</td></tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card mb-0">
            <div class="card-header py-2"><h3 class="card-title fs-6 mb-0">Top khách hàng quay lại</h3></div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0 align-middle">
                    <thead class="table-light"><tr><th>Khách hàng</th><th>Lần đặt</th></tr></thead>
                    <tbody>
                        @{
                            var repeatCustomers = ViewData["RepeatCustomers"] as List<dynamic>;
                            if (repeatCustomers != null && repeatCustomers.Count > 0)
                            {
                                foreach (var customer in repeatCustomers)
                                {
                                    <tr>
                                        <td><span class="fw-bold">@customer.Name</span><br /><small class="text-muted">@customer.Phone</small></td>
                                        <td><span class="badge text-bg-primary">@customer.Count</span></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="2" class="text-center text-muted py-3">Chưa có khách quay lại</td></tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    const daysLabels = @Html.Raw(ViewData["DaysLabels"]);
    const daysCounts = @Html.Raw(ViewData["DaysCounts"]);
    const serviceLabels = @Html.Raw(ViewData["ServiceLabels"]);
    const serviceCounts = @Html.Raw(ViewData["ServiceCounts"]);
    const statusPending = @ViewData["StatusPending"];
    const statusConfirmed = @ViewData["StatusConfirmed"];
    const statusCompleted = @ViewData["StatusCompleted"];
    const statusCancelled = @ViewData["StatusCancelled"];

    new Chart(document.getElementById('bookingChart').getContext('2d'), {
        type: 'bar',
        data: {
            labels: daysLabels,
            datasets: [{ label: 'Số lượng đặt lịch', data: daysCounts, backgroundColor: '#0d6efd', borderRadius: 5 }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
    });

    new Chart(document.getElementById('statusChart').getContext('2d'), {
        type: 'doughnut',
        data: {
            labels: ['Chờ xác nhận', 'Đã xác nhận', 'Hoàn thành', 'Đã hủy'],
            datasets: [{
                data: [statusPending, statusConfirmed, statusCompleted, statusCancelled],
                backgroundColor: ['#ffc107', '#0dcaf0', '#198754', '#dc3545'],
                borderColor: '#fff', borderWidth: 2
            }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
    });

    new Chart(document.getElementById('serviceChart').getContext('2d'), {
        type: 'bar',
        data: {
            labels: serviceLabels,
            datasets: [{ label: 'Số lần đặt', data: serviceCounts, backgroundColor: ['#0d6efd', '#6f42c1', '#20c997', '#fd7e14', '#dc3545'], borderRadius: 5 }]
        },
        options: {
            indexAxis: 'y', responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { x: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
    });
</script>