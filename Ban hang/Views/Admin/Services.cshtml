@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý Dịch vụ";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">Danh sách dịch vụ</h3>
        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#serviceModal" onclick="openCreateModal()">
            <i class="bi bi-plus-lg"></i> Thêm dịch vụ
        </button>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped mb-0" id="servicesTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Tên dịch vụ</th>
                    <th>Mô tả</th>
                    <th>Giá</th>
                    <th style="width:150px">Thao tác</th>
                </tr>
            </thead>
            <tbody id="servicesTableBody">
                <!-- Dữ liệu sẽ được Ajax đổ vào đây -->
            </tbody>
        </table>
    </div>
</div>

<!-- MODAL Thêm/Sửa -->
<div class="modal fade" id="serviceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Thêm dịch vụ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="serviceId" value="0" />

                <div class="mb-3">
                    <label class="form-label">Icon</label>
                    <select id="serviceIconKey" class="form-select">
                        <option value="spa">Spa</option>
                        <option value="vet">Thú y</option>
                        <option value="hotel">Khách sạn</option>
                        <option value="train">Huấn luyện</option>
                        <option value="walk">Đi dạo</option>
                        <option value="taxi">Pet Taxi</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Tên dịch vụ</label>
                    <input id="serviceTitle" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <textarea id="serviceDescription" class="form-control" rows="3"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Giá</label>
                    <input id="servicePrice" class="form-control" placeholder="Từ 150.000đ" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" onclick="saveService()">Lưu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let isEditMode = false;

        // Load danh sách khi trang vừa mở
        $(document).ready(function () {
            loadServices();
        });

        function loadServices() {
            $.get('/Admin/GetServicesJson', function (data) {
                let html = '';
                data.forEach(function (item) {
                    html += `
                        <tr>
                            <td>${item.id}</td>
                            <td>${item.title}</td>
                            <td>${item.description}</td>
                            <td>${item.price}</td>
                            <td>
                                <button class="btn btn-sm btn-warning" onclick='openEditModal(${JSON.stringify(item)})'>
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-danger" onclick="deleteService(${item.id})">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                });
                $('#servicesTableBody').html(html);
            });
        }

        function openCreateModal() {
            isEditMode = false;
            $('#modalTitle').text('Thêm dịch vụ');
            $('#serviceId').val(0);
            $('#serviceIconKey').val('spa');
            $('#serviceTitle').val('');
            $('#serviceDescription').val('');
            $('#servicePrice').val('');
        }

        function openEditModal(item) {
            isEditMode = true;
            $('#modalTitle').text('Sửa dịch vụ');
            $('#serviceId').val(item.id);
            $('#serviceIconKey').val(item.iconKey);
            $('#serviceTitle').val(item.title);
            $('#serviceDescription').val(item.description);
            $('#servicePrice').val(item.price);
            new bootstrap.Modal(document.getElementById('serviceModal')).show();
        }

        function saveService() {
            const payload = {
                id: parseInt($('#serviceId').val()),
                iconKey: $('#serviceIconKey').val(),
                title: $('#serviceTitle').val(),
                description: $('#serviceDescription').val(),
                price: $('#servicePrice').val()
            };

            if (!payload.title.trim()) {
                alert('Vui lòng nhập tên dịch vụ.');
                return;
            }

            const url = isEditMode ? '/Admin/AjaxEditService' : '/Admin/AjaxCreateService';

            $.ajax({
                url: url,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload),
                success: function (res) {
                    bootstrap.Modal.getInstance(document.getElementById('serviceModal')).hide();
                    loadServices();
                },
                error: function () {
                    alert('Có lỗi xảy ra, vui lòng thử lại.');
                }
            });
        }

        function deleteService(id) {
            if (!confirm('Bạn chắc chắn muốn xóa dịch vụ này?')) return;

            $.ajax({
                url: '/Admin/AjaxDeleteService',
                type: 'POST',
                data: { id: id },
                success: function () {
                    loadServices();
                }
            });
        }
    </script>
}